# Gemini
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"
CAPIX_USE_VERTEX_AI="false"
GOOGLE_CLOUD_PROJECT="your-google-cloud-project"
GOOGLE_CLOUD_LOCATION="global"

# MongoDB MCP hosted endpoint. If unset, the router tries direct MONGO_URI before falling back
# to bundled demo nodes.
MONGODB_MCP_URL="https://your-mongodb-mcp-host.example.com/mcp"
MONGODB_MCP_TOKEN="optional-bearer-token"
MONGODB_MCP_FIND_TOOL="find"
MONGODB_MCP_DATABASE="capix_compute_db"
MONGODB_MCP_NODES_COLLECTION="nodes"
MONGODB_MCP_INFERENCE_COLLECTION="inference_routes"

# Official MongoDB MCP server runtime env. Keep these on the MCP host, not in the
# private CapIX browser bundle. MDB_MCP_VOYAGE_API_KEY is only needed for Atlas
# integrated AI / vector search embedding tools.
MDB_MCP_CONNECTION_STRING="${MONGO_URI}"
MDB_MCP_TRANSPORT="http"
MDB_MCP_READ_ONLY="true"
MDB_MCP_HTTP_HOST="127.0.0.1"
MDB_MCP_HTTP_PORT="8794"
MDB_MCP_HTTP_BODY_RESPONSE_TYPE="json"
MDB_MCP_VOYAGE_API_KEY="your-atlas-integrated-ai-model-key"

# Optional direct Mongo connection for seeding and for demos before the MCP HTTP server is deployed.
MONGO_URI="mongodb://localhost:27017/"
MONGODB_DB="capix_compute_db"
MONGODB_NODES_COLLECTION="nodes"
MONGODB_INFERENCE_COLLECTION="inference_routes"

# Optional JSON HTTP wrapper used by the private CapIX app.
CAPIX_ROUTER_HOST="0.0.0.0"
CAPIX_ROUTER_PORT="8788"
CAPIX_ROUTER_TOKEN="match-private-app-CAPIX_ROUTER_TOKEN"
CAPIX_REQUIRE_PAID_ROUTE_KEY="false"
CAPIX_PRIVATE_POLICY_URL="https://capix.network/api/router/private-policy"
CAPIX_PRIVATE_POLICY_TOKEN="private-policy-service-token"

# One-shot pull from the private CapIX app into MongoDB.
CAPIX_SNAPSHOT_URL="https://capix.network/api/router/compute-snapshot"
CAPIX_ROUTER_SYNC_TOKEN="match-private-app-CAPIX_ROUTER_SYNC_TOKEN"
CAPIX_SNAPSHOT_OUT="examples/capix_compute_snapshot.json"
